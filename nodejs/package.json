{
  "name": "logosdb",
  "version": "1.0.0",
  "description": "Fast semantic vector database (HNSW + mmap) - Node.js bindings",
  "main": "lib/index.js",
  "types": "types/index.d.ts",
  "config": {
    "runtime": "napi",
    "target": "8"
  },
  "scripts": {
    "vendor-core": "node ./scripts/vendor-core.mjs",
    "prepublishOnly": "node ./scripts/vendor-core.mjs",
    "install": "prebuild-install --runtime napi --target 8 || node-gyp rebuild -j 1",
    "build": "node-gyp rebuild -j 1",
    "test": "mocha test/test.js",
    "native:prebuild": "prebuild --runtime napi --all --strip",
    "native:prebuild-upload": "prebuild --runtime napi --all --strip --upload-all"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jose-compu/logosdb.git"
  },
  "keywords": [
    "vector-database",
    "hnsw",
    "embeddings",
    "semantic-search",
    "nearest-neighbor",
    "native-addon"
  ],
  "author": "Jose",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/jose-compu/logosdb/issues"
  },
  "homepage": "https://github.com/jose-compu/logosdb#readme",
  "dependencies": {
    "bindings": "^1.5.0",
    "node-addon-api": "^7.0.0",
    "prebuild-install": "npm:@mmomtchev/prebuild-install@^1.0.2"
  },
  "devDependencies": {
    "mocha": "^10.2.0",
    "node-gyp": "^11.2.0",
    "prebuild": "^12.1.0"
  },
  "binary": {
    "napi_versions": [
      8
    ]
  },
  "gypfile": true,
  "files": [
    "binding.gyp",
    "lib",
    "src",
    "types",
    "test",
    "deps",
    "scripts"
  ],
  "engines": {
    "node": ">=16.0.0"
  },
  "os": [
    "darwin",
    "linux",
    "win32"
  ],
  "cpu": [
    "x64",
    "arm64"
  ]
}
